## 8. Proposed Code Improvements

### 8.1 SmartAgent: Decompose `sendToAI()`

The current 270-line `sendToAI()` should be split into focused methods:

```ring
func sendToAI(cMessage, cRequestType, cCurrentCode)
    try
        oContext = prepareContext(cMessage, cRequestType, cCurrentCode)
        aConversation = buildInitialConversation(oContext)
        
        nMaxIterations = 25
        nIteration = 0
        aToolsUsed = []
        
        while nIteration < nMaxIterations
            nIteration++
            processUIEvents()
            
            oAIResponse = dispatchToProvider(aConversation, cMessage)
            if not oAIResponse[:success]
                return createErrorResponse("AI request failed: " + oAIResponse[:error])
            ok
            
            updateTokenCount(oAIResponse)
            displayThoughtAndMessage(oAIResponse)
            
            if getResponseType(oAIResponse) = "function_call"
                oToolResult = executeToolSafely(oAIResponse, aToolsUsed)
                appendToolResultToConversation(aConversation, oAIResponse, oToolResult)
                loop
            ok
            
            return finalizeResponse(oAIResponse, aToolsUsed)
        end
        
        return createSuccessResponse("Tools executed successfully.")
    catch
        return createErrorResponse("AI request error: " + cCatchError)
    done
```

### 8.2 Add Tool Execution Timeout

```ring
# In AgentTools
func executeCommandSafe(cCommand, nTimeoutSec)
    if isCommandBlacklisted(cCommand)
        return createErrorResult("SECURITY ERROR: Blacklisted command.")
    ok
    
    try
        cTempOut = "cmd_" + clock() + ".tmp"
        cTempErr = "cmd_" + clock() + ".err"
        
        if iswindows()
            # Windows: use cmd /c with output redirect
            cWrapped = 'cmd /c "' + cCommand + ' > ' + cTempOut + ' 2> ' + cTempErr + '"'
        else
            cWrapped = "timeout " + nTimeoutSec + " sh -c '" + cCommand + "' > " + cTempOut + " 2> " + cTempErr
        ok
        
        nStart = clock()
        systemcmd(cWrapped)
        nDuration = (clock() - nStart) / clockspersecond()
        
        cOutput = ""
        if fexists(cTempOut) cOutput = read(cTempOut) remove(cTempOut) ok
        cErr = ""
        if fexists(cTempErr) cErr = read(cTempErr) remove(cTempErr) ok
        
        if cErr != ""
            cOutput += nl + "[STDERR]: " + cErr
        ok
        
        return createSuccessResult("Command executed (" + nDuration + "s):" + nl + cOutput)
    catch
        return createErrorResult("Command failed: " + cCatchError)
    done
```

### 8.3 Agent State Machine

Replace the simple while loop with a formal state machine:

```ring
# Agent States
AGENT_IDLE         = 0
AGENT_PLANNING     = 1
AGENT_CALLING_LLM  = 2
AGENT_EXEC_TOOL    = 3
AGENT_REFLECTING   = 4
AGENT_FINALIZING   = 5
AGENT_ERROR        = 6

class AgentStateMachine

    nCurrentState = AGENT_IDLE
    nMaxTransitions = 100
    aStateLog = []
    
    func transition nNewState
        aStateLog + [
            ["from", nCurrentState],
            ["to", nNewState],
            ["timestamp", clock()]
        ]
        nCurrentState = nNewState
    
    func canTransition nTo
        # Define valid state transitions
        switch nCurrentState
            on AGENT_IDLE
                return nTo = AGENT_PLANNING
            on AGENT_PLANNING
                return nTo = AGENT_CALLING_LLM
            on AGENT_CALLING_LLM
                return nTo = AGENT_EXEC_TOOL or nTo = AGENT_FINALIZING or nTo = AGENT_ERROR
            on AGENT_EXEC_TOOL
                return nTo = AGENT_REFLECTING or nTo = AGENT_CALLING_LLM or nTo = AGENT_ERROR
            on AGENT_REFLECTING
                return nTo = AGENT_CALLING_LLM or nTo = AGENT_FINALIZING
            on AGENT_ERROR
                return nTo = AGENT_REFLECTING or nTo = AGENT_FINALIZING
        off
        return false
    
    func getStateLog
        return aStateLog
```

